{
  "compilerOptions": {
    // "baseUrl": ".",
    "target": "esnext",
    "module": "node16",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    // "ignoreDeprecations": "6.0",
  },
  "include": [
    "./src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}